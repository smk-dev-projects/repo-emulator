{
  "name": "repo-emulator",
  "version": "0.1.0",
  "description": "A Git repository emulator for testing, learning, and experimentation",
  "main": "dist/index.js",
  "bin": {
    "repo-emulator": "./dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docs": "typedoc --out docs/api src",
    "docs:serve": "npx http-server docs/api",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/repo-emulator.git"
  },
  "keywords": [
    "git",
    "emulator",
    "repository",
    "version-control",
    "learning",
    "testing",
    "simulation"
  ],
  "author": "Sumukha Rajendra",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yourusername/repo-emulator/issues"
  },
  "homepage": "https://github.com/yourusername/repo-emulator#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jest": "^27.0.0",
    "jest": "^29.6.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ]
}
